# =============================================================================
# Core Settings
# =============================================================================
DEV_MODE=true
ALLOW_REGISTRATIONS=true
SITE_URL=https://ai-studio.localhost:4000
AUTH_SERVER_URL=https://ai-studio.localhost:4000
ADMIN_EMAIL=admin@example.com
FROM_EMAIL=noreply@example.com
CERT_FILE=/app/certs/tls-certificate.pem
KEY_FILE=/app/certs/tls-private-key.pem

# =============================================================================
# Database
# =============================================================================
DATABASE_TYPE=postgres
DATABASE_URL=postgresql://tykuser:tykSecurePass123@postgres:5432/tyk_ai_studio?sslmode=disable

# =============================================================================
# Security - CHANGE THESE
# =============================================================================
TYK_AI_SECRET_KEY=change-me-32-char-ai-studio-secret
MICROGATEWAY_ENCRYPTION_KEY=change-me-32-char-encryption-key

# =============================================================================
# Hub-Spoke: Control Plane Mode
# =============================================================================
GATEWAY_MODE=control
GRPC_PORT=50051
GRPC_HOST=0.0.0.0
GRPC_TLS_INSECURE=true
GRPC_AUTH_TOKEN=change-me-grpc-auth-token

# =============================================================================
# Proxy - Point to external Edge Gateway URL
# =============================================================================
PROXY_URL=http://localhost:9091
TOOL_DISPLAY_URL=http://localhost:9091
DATASOURCE_DISPLAY_URL=http://localhost:9091

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
DEBUG_HTTP=false
DEBUG_HTTP_PROXY=false
PLUGIN_COMMAND_ALLOWLIST=/plugins,/app/plugins
BRANDING_STORAGE_PATH=/app/data/branding

# =============================================================================
# Plugin Marketplace (Optional - enables browsing and installing plugins)
# =============================================================================
# AI_STUDIO_OCI_CACHE_DIR must be set to enable the marketplace.
# Without it, the Marketplace page will be empty.
MARKETPLACE_ENABLED=true
MARKETPLACE_INDEX_URL=https://raw.githubusercontent.com/TykTechnologies/tyk-ai-studio-plugins-ce/main/index.yaml
MARKETPLACE_SYNC_INTERVAL=1h
MARKETPLACE_CACHE_DIR=/app/data/cache/marketplace
AI_STUDIO_OCI_CACHE_DIR=/app/data/cache/plugins
AI_STUDIO_OCI_REQUIRE_SIGNATURE=false

# =============================================================================
# SMTP (Optional - required for email invites/notifications)
# =============================================================================
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
